# erlang_write_safety.rules
# Technology: erlang | Capability: write

rule erlang-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "os:cmd"
  MESSAGE "Blocked an unsafe pattern in erlang. Use the recommended best practices for 2025/2026."
}

rule erlang-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "erlang:now()"
  MESSAGE "You are using an outdated API for erlang. Please upgrade to the newer API."
}
